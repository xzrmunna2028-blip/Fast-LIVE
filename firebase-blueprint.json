{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile inside VoxaClub",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "User's unique Firebase UID"
        },
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50,
          "description": "Display name of the user"
        },
        "avatar": {
          "type": "string",
          "description": "URL of the user's avatar image"
        },
        "phone": {
          "type": "string",
          "description": "Phone number"
        },
        "email": {
          "type": "string",
          "description": "Email address"
        },
        "authProvider": {
          "type": "string",
          "enum": ["phone", "google", "facebook", "email"]
        },
        "country": {
          "type": "string",
          "description": "User's country"
        },
        "countryFlag": {
          "type": "string",
          "description": "Emoji flag of the country"
        },
        "birthday": {
          "type": "string"
        },
        "gender": {
          "type": "string"
        },
        "bio": {
          "type": "string",
          "maxLength": 160
        },
        "description": {
          "type": "string"
        },
        "hasTigerCrown": {
          "type": "boolean"
        },
        "vipLevel": {
          "type": "number"
        }
      },
      "required": ["id", "name", "avatar", "authProvider", "country", "countryFlag"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of registered user profiles"
    }
  }
}
